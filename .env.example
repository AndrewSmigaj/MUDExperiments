# Copy to .env and adjust. .env is gitignored.
# Compose reads this file for ${...} interpolation AND injects it into the
# evennia container (env_file), where settings.py reads the Postgres vars.

# --- Postgres ---
POSTGRES_DB=whiteout
POSTGRES_USER=whiteout
POSTGRES_PASSWORD=changeme-dev-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Evennia admin superuser (created idempotently by `make accounts`) ---
EVENNIA_SUPERUSER=admin
EVENNIA_SUPERUSER_EMAIL=admin@example.com
EVENNIA_SUPERUSER_PASSWORD=changeme-admin-password

# --- Bot player account (non-superuser; used by the agent/ harness) ---
AGENT_ACCOUNT=agent-1
AGENT_ACCOUNT_EMAIL=agent@example.com
AGENT_ACCOUNT_PASSWORD=changeme-agent-password
